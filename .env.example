# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets (it's in .gitignore).

# --- Database ---

# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://prism:your_secure_password_here@db:5432/prism

# Used by Docker Compose — change to a strong unique password
DB_PASSWORD=your_secure_password_here

# --- Redis ---

REDIS_URL=redis://redis:6379

# --- Application ---

NODE_ENV=production
PORT=3000

# Public URL where users access the dashboard.
# If using HTTPS (recommended): https://your-domain.com or https://your-server-ip
# The setup wizard will help you configure this correctly.
APP_URL=http://localhost:3000

# --- Security Secrets ---
# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=generate_a_random_32_character_string_here
PIN_ENCRYPTION_KEY=generate_another_random_32_character_string

# Used for encrypting OAuth tokens at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_64_hex_character_string_here

# --- Google Calendar ---
# Get credentials at: https://console.cloud.google.com
# Enable "Google Calendar API", create OAuth 2.0 Client ID

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URIs are now derived automatically from the host you reach Prism on
# (honoring X-Forwarded-Host behind a reverse proxy), so these *_REDIRECT_URI
# vars are OPTIONAL fallbacks. You still must register your real callback URL(s)
# in the Google Cloud Console — e.g. https://your-domain.com/api/auth/google/callback
# and .../api/auth/google-bus/callback — exactly (https, no trailing slash).
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/google-bus/callback

# --- Apple iCloud/Calendar ---
# Use an APP-SPECIFIC PASSWORD (not your regular password).
# Generate at: https://appleid.apple.com > Security > App-Specific Passwords
# Requires 2FA enabled on your Apple account.

APPLE_ID=your-apple-id@icloud.com
APPLE_APP_PASSWORD=your-app-specific-password

# --- Microsoft (To Do, OneDrive) ---
# Register app at: https://portal.azure.com > App registrations
# Account type: Personal Microsoft accounts only
# API permissions: Tasks.ReadWrite, Files.Read

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Redirect URI is derived automatically from the request host now (optional
# fallback below). Register your real callback URL in Azure exactly, e.g.
# https://your-domain.com/api/auth/microsoft/callback
# MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# --- Weather ---
# Select provider: "meteo" (Open-Meteo, default — no API key required),
# "pirate" (Pirate Weather, includes minutely precip), or "openweather"
# (OpenWeatherMap, legacy).
WEATHER_PROVIDER=meteo

# Coordinates used by all providers (Open-Meteo requires them; Pirate Weather
# requires them; OpenWeatherMap will fall back to the WEATHER_LOCATION string
# when these are unset). Default: downtown Chicago.
WEATHER_LAT=41.8781
WEATHER_LON=-87.6298
# Display name shown in the widget.
WEATHER_LOCATION=Springfield,IL,US

# Pirate Weather (Dark Sky-compatible) — https://pirateweather.net
# Only required when WEATHER_PROVIDER=pirate. Free tier: 10K calls/month.
PIRATE_WEATHER_API_KEY=your-pirate-weather-api-key

# OpenWeatherMap — https://openweathermap.org/api
# Only required when WEATHER_PROVIDER=openweather. Free tier: 1000 calls/day.
OPENWEATHER_API_KEY=your-openweathermap-api-key

# --- Enphase Solar (Optional) ---
# Get credentials at: https://developer-v4.enphase.com

ENPHASE_API_KEY=your-enphase-api-key
ENPHASE_SYSTEM_ID=your-enphase-system-id

# --- Sonos (Optional) ---
# Get credentials at: https://developer.sonos.com (requires developer approval)

SONOS_CLIENT_ID=your-sonos-client-id
SONOS_CLIENT_SECRET=your-sonos-client-secret
SONOS_REDIRECT_URI=http://localhost:3000/api/auth/sonos/callback

# --- Iframe Embedding (Home Assistant, etc.) ---
# Allow Prism to be embedded in an iframe from specific origins.
# Comma-separated list, or * to allow all origins.
# Example: http://homeassistant.local:8123, https://my-ha.example.com
# ALLOWED_FRAME_ANCESTORS=http://homeassistant.local:8123

# --- Alexa Skill (optional) ---
# Both required to enable the /api/alexa webhook in production.
#
# ALEXA_VOICE_TOKEN: a 'voice'-scoped API token generated at
#   Settings -> Security -> API Tokens. The webhook uses this to call
#   /api/v1/voice/* on behalf of the household.
#
# ALEXA_SKILL_ID: the "Your Skill ID" value from the Alexa Developer
#   Console (format: amzn1.ask.skill.<uuid>). Required so the webhook
#   refuses requests originating from any other Alexa skill, even if
#   they carry a valid Amazon-signed cert chain.

# ALEXA_VOICE_TOKEN=your-voice-scoped-api-token
# ALEXA_SKILL_ID=amzn1.ask.skill.your-skill-id

# --- Backups (prism-backup container) ---
#
# The backup container always dumps the database locally to ./backups. The
# settings below are optional and per-deployment — leave them blank to keep
# backups local-only.
#
# RCLONE_REMOTE: an rclone remote + path to copy backups off-site, e.g.
#   onedrive:Prism/backups. Requires a configured ./config/rclone.conf.
#   User assets under data/ are synced to <remote-parent>/data alongside it.
# RCLONE_RETENTION_DAYS: how long to keep off-site backups (default 30).
# BACKUP_HOUR: hour of day (0-23) to run the daily backup (default 3).
# RETENTION_DAYS: how long to keep local backups (default 7).
# HC_URL: a healthchecks.io (or compatible) ping URL for dead-man monitoring.
#   The job pings <URL>/start, then <URL> on success or <URL>/fail on error.
#   Generate your OWN check — do not reuse anyone else's UUID.

# RCLONE_REMOTE=onedrive:Prism/backups
# RCLONE_RETENTION_DAYS=30
# BACKUP_HOUR=3
# RETENTION_DAYS=7
# HC_URL=https://hc-ping.com/your-own-uuid-here

# --- Future Integrations (leave blank) ---

# HOMEBRIDGE_URL=http://homebridge-host:8581
# HOMEBRIDGE_USERNAME=admin
# HOMEBRIDGE_PASSWORD=your-homebridge-password

# LIFE360_USERNAME=your-email@example.com
# LIFE360_PASSWORD=your-life360-password
