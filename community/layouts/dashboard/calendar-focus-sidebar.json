{
  "type": "prism-layout",
  "version": 2,
  "mode": "dashboard",
  "name": "Calendar Focus",
  "description": "Cal, Clk, Wtr, Bdy, Msg in landscape",
  "author": "Sandy Dargoport",
  "tags": ["calendar focus", "big calendar"],
  "screenSizes": ["1920x1080", "2560x1440", "3840x2160"],
  "orientation": "landscape",
  "widgets": [
    { "i": "calendar", "x": 0, "y": 0, "w": 9, "h": 16, "minW": 3, "minH": 4 },
    { "i": "clock", "x": 9, "y": 0, "w": 3, "h": 3, "minW": 2, "minH": 2 },
    { "i": "weather", "x": 9, "y": 3, "w": 3, "h": 3, "minW": 2, "minH": 2 },
    { "i": "birthdays", "x": 9, "y": 6, "w": 3, "h": 4, "minW": 2, "minH": 3 },
    { "i": "messages", "x": 9, "y": 10, "w": 3, "h": 6, "minW": 2, "minH": 3 }
  ]
}
