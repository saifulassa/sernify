{
  "_comment": "Copy this file to user-settings.json and customize for your family",

  "family": {
    "name": "The Demo Family",
    "members": [
      {
        "id": "parent1",
        "name": "Alex",
        "role": "parent",
        "color": "#3B82F6"
      },
      {
        "id": "parent2",
        "name": "Jordan",
        "role": "parent",
        "color": "#EC4899"
      },
      {
        "id": "child1",
        "name": "Emma",
        "role": "child",
        "color": "#10B981"
      },
      {
        "id": "child2",
        "name": "Sophie",
        "role": "child",
        "color": "#F59E0B"
      }
    ]
  },

  "display": {
    "defaultView": "multiWeek",
    "theme": "auto",
    "seasonalThemes": true,
    "idleTimeout": 120,
    "idleMode": "photos",
    "darkModeSchedule": {
      "enabled": true,
      "mode": "sunset",
      "customTimes": {
        "darkModeStart": "19:00",
        "lightModeStart": "07:00"
      }
    }
  },

  "integrations": {
    "googleCalendar": true,
    "appleCalendar": true,
    "microsoftToDo": true,
    "icloudPhotos": true,
    "onedrive": true,
    "enphase": false,
    "sonos": false,
    "homebridge": false
  },

  "notifications": {
    "eventReminders": true,
    "choreReminders": true,
    "maintenanceReminders": true,
    "weatherAlerts": true,
    "soundEnabled": false
  },

  "privacy": {
    "showLocationMap": false,
    "locationHistoryDays": 7,
    "photoFaceBlur": false,
    "hideCalendarInAwayMode": true
  }
}
